{
  "name": "portunix-pdf-viewer",
  "displayName": "Portunix PDF Viewer",
  "description": "Display pdf file in VSCode.",
  "version": "1.3.3",
  "publisher": "cassandragargoyle",
  "engines": {
    "vscode": "^1.46.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "pdf",
    "viewer"
  ],
  "icon": "vscode-pdf-portunix.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/cassandragargoyle/portunix-vscode-pdf-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/cassandragargoyle/portunix-vscode-pdf-viewer/issues"
  },
  "activationEvents": [
    "onCustomEditor:pdf.preview"
  ],
  "main": "./out/src/extension",
  "contributes": {
    "capabilities": {
      "untrustedWorkspaces": {
        "supported": true
      }
    },
    "customEditors": [
      {
        "viewType": "pdf.preview",
        "displayName": "Pdf Preview",
        "selector": [
          {
            "filenamePattern": "*.pdf"
          }
        ]
      }
    ],
    "configuration": {
      "type": "object",
      "title": "PDF Preview",
      "properties": {
        "pdf-preview.default.cursor": {
          "markdownDescription": "The default cursor tool for preview.",
          "type": "string",
          "default": "select",
          "enum": [
            "select",
            "hand"
          ]
        },
        "pdf-preview.default.scale": {
          "markdownDescription": "The default zoom level for preview. Allowed values are `auto`, `page-actual`, `page-fit`, `page-width`, and 1-based scale values. (`1.0` means 100%)",
          "type": "string",
          "default": "auto",
          "pattern": "^(\\d+(?:\\.\\d+)?|auto|page-actual|page-fit|page-width)$"
        },
        "pdf-preview.default.sidebar": {
          "markdownDescription": "Show the sidebar on load. The default visibility of sidebar for preview.",
          "type": "boolean",
          "default": false
        },
        "pdf-preview.default.scrollMode": {
          "markdownDescription": "The default scroll mode for preview.",
          "type": "string",
          "default": "vertical",
          "enum": [
            "vertical",
            "horizontal",
            "wrapped"
          ]
        },
        "pdf-preview.default.spreadMode": {
          "markdownDescription": "The default spread mode for preview.",
          "type": "string",
          "default": "none",
          "enum": [
            "none",
            "odd",
            "even"
          ]
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "lint": "eslint ./src",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "smoke": "npm test",
    "package": "npx --yes @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.0",
    "@types/vscode": "^1.46.0",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-prettier": "^5.5.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "prettier": "^3.6.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0"
  },
  "extensionKind": [
    "ui"
  ]
}
